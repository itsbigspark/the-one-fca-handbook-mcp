    <xs:complexType name="PIIDetailStructure">
         <xs:sequence>
             <xs:element name="PolicyExcessDetail" type="PIIPolicyExcessStructure"   minOccurs="0" maxOccurs="unbounded"/>
             <xs:element name="PolicyExclusionDetail" type="PIIPolicyExclusionStructure"   minOccurs="0" maxOccurs="unbounded"/>             
          </xs:sequence>
     </xs:complexType>         
    
    <xs:complexType name="PIIPolicyExcessStructure">
        <xs:sequence>
            <xs:element name="BusinessLine" type="PIIExcessBusinessLineType"     minOccurs="0"/>
            <xs:element name="PolicyExcess" type="NonNegativeMonetaryType" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
   

