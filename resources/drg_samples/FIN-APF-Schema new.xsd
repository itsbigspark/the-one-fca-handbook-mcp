<xs:schema 
    xmlns:xs=               "http://www.w3.org/2001/XMLSchema" 
    elementFormDefault=     "qualified"
    attributeFormDefault=   "unqualified" 
   
   targetNamespace=         "urn:fsa-gov-uk:MER:FIN-APF:4"
    xmlns=                  "urn:fsa-gov-uk:MER:FIN-APF:4" 
    xmlns:mer-meta=         "urn:fsa-gov-uk:MER:Meta-Data:1" 
    
    version="4"
    id="MER-FIN-APF">

    <xs:annotation>
        <xs:documentation>
            <mer-meta:DataItemReference>FIN-APF</mer-meta:DataItemReference>
            <mer-meta:DataItemName>Authorised Professional Firms Questionnaire</mer-meta:DataItemName>
        </xs:documentation>
    </xs:annotation>

    <xs:include schemaLocation="../../CommonTypes/v11/CommonTypes-Schema.xsd"/>

    <xs:element name="FIN-APF-Questionnaire">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="ProfessionalRegulation" minOccurs="1">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="DesignatedProfBody" minOccurs="1" >                            
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="The Association of Chartered Certified Accountants"/>
                                        <xs:enumeration value="The Institute of Actuaries"/>
                                        <xs:enumeration value="The Institute of Chartered Accountants in England and Wales"/>
                                        <xs:enumeration value="The Institute of Chartered Accountants in Ireland"/>
                                        <xs:enumeration value="The Institute of Chartered Accountants of Scotland"/>
                                        <xs:enumeration value="The Law Society of England and Wales"/>
                                        <xs:enumeration value="The Law Society of Scotland"/>
                                        <xs:enumeration value="The Law Society of Northern Ireland" />
                                        <xs:enumeration value="The Council for Licensed Conveyancers" />
                                        <xs:enumeration value="The Royal Institution of Chartered Surveyors" />
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>                     
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
                <xs:element name="SupervisionAndMonitoring" minOccurs="1" >
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="AppointedReps"                    type="xs:nonNegativeInteger"    minOccurs="0" />
                            <xs:element name="TotalIncomeRegulatedActivities"   type="MonetaryType"             minOccurs="1" />
                            <xs:element name="PctOfTotalIncome"                                                 minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="PctInvestmentManagement"      type="PercentDP0Type"   minOccurs="0" />
                                        <xs:element name="PctCorporateFinance"          type="PercentDP0Type"   minOccurs="0" />
                                        <xs:element name="PctRetailInvestment"          type="PercentDP0Type"   minOccurs="0" />
                                        <xs:element name="PctHomeFinanceMediation"      type="PercentDP0Type"   minOccurs="0" />
                                        <xs:element name="PctInsuranceDistribution"     type="PercentDP0Type"   minOccurs="0" />
                                        <xs:element name="PctCreditRelated"             type="PercentDP0Type"   minOccurs="0" />
                                        <xs:element name="PctOther"                     type="PercentDP0Type"   minOccurs="0" />
                                    </xs:sequence>
                                </xs:complexType>                             
                            </xs:element>
                        </xs:sequence>
                    </xs:complexType>   
                </xs:element>
                <xs:element name="ClientMoneyAndAssets" minOccurs="1">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="HoldClientMoney"      type="YesNoType" minOccurs="1" />
                            <xs:element name="HoldClientAssets"     type="YesNoType" minOccurs="1" />
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
                <xs:element name="MaterialChanges" minOccurs="1">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="NotifiedFCA" type="YesNoType" minOccurs="1" />
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
                <xs:element name="ProfessionalIndemnityInsurance" minOccurs="1">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="IndemnityInsurance" type="YesNoType" minOccurs="1" />
                            <xs:element name="CurrentPolicyDetails" minOccurs="0" maxOccurs="unbounded">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="PIIBasicInformation"      type="PIIBasicStructure" minOccurs="0" /> 
                                        <xs:element name="PIIDetailedInformation"   type="PIIDetailStructure" minOccurs="0" />
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
                <xs:element name="FinancialResourcesReporting" minOccurs="1">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="TotalIncomeAllActivities"     type="MonetaryType" minOccurs="1" />
                            <xs:element name="ProfitAfterTax"               type="YesNoType" minOccurs="1" />
                            <xs:element name="CurrentFutureLiabilities"     type="YesNoType" minOccurs="1" />
                            <xs:element name="ActAsInvestmentManager"       type="YesNoType" minOccurs="1" />
                            <xs:element name="DiscretionaryManagementServices" minOccurs="0">
                               <xs:complexType>
                                   <xs:sequence>
                                       <xs:element name="InvestmentManagementRetailClients"     type="YesNoType" minOccurs="0" />
                                       <xs:element name="InvestmentManagementProfClients"       type="YesNoType" minOccurs="0" />
                                       <xs:element name="InvestmentManagementNonUKClients"      type="YesNoType" minOccurs="0" />
                                       <xs:element name="TrusteeActivities"                     type="YesNoType" minOccurs="0" />
                                       <xs:element name="ISAManagement"                         type="YesNoType" minOccurs="0" />
                                   </xs:sequence>
                               </xs:complexType> 
                            </xs:element>
                            <xs:element name="StateOther"                       type="String100Type" minOccurs="0" />
                            <xs:element name="FundsUnderDiscretionaryMgmt"      type="MonetaryType" minOccurs="0" />
                            <xs:element name="TotalFundsUnderDiscretionaryMgmt"  type="MonetaryType" minOccurs="0" />
                        </xs:sequence>
                    </xs:complexType>   
                </xs:element>                             
            </xs:sequence>    
            <xs:attributeGroup ref="CurrencyAndUnitsAttrGroup"/>
        </xs:complexType>
    </xs:element>
          
    
