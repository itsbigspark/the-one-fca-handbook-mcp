                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element name="SingleRequired" type="NonNegativeMonetaryType" minOccurs="0" />
                        <xs:element name="AggregateRequiredLimit" minOccurs="0">           
                            <xs:simpleType>
                                <xs:restriction base="xs:string">
                                    <xs:enumeration value="GBP"/>
                                    <xs:enumeration value="EUR"/>
                                    <xs:enumeration value="Unlimited"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element name="AggregateRequired" type="NonNegativeMonetaryType" minOccurs="0" />
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="IndemnityLimits" minOccurs="0">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="SingleIndemnityLimit" minOccurs="0">           
                            <xs:simpleType>
                                <xs:restriction base="xs:string">
                                    <xs:enumeration value="GBP"/>
                                    <xs:enumeration value="EUR"/>
                                    <xs:enumeration value="Unlimited"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element name="Single" type="NonNegativeMonetaryType" minOccurs="0" />
                        <xs:element name="AggregateIndemnityLimit" minOccurs="0">           
                            <xs:simpleType>
                                <xs:restriction base="xs:string">
                                    <xs:enumeration value="GBP"/>
                                    <xs:enumeration value="EUR"/>
                                    <xs:enumeration value="Unlimited"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
