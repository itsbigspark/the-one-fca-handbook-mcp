      <xs:enumeration value="Mortgages - Endowments" />
      <xs:enumeration value="Mortgages - Equity release" />
      <xs:enumeration value="Mortgages - Other Mortgage type" />
      <xs:enumeration value="Retail investments - Standard/general" />
      <xs:enumeration value="Retail investments - Income drawdown / withdrawal" />
      <xs:enumeration value="Retail investments - Investment bonds" />
      <xs:enumeration value="Retail investments - Personal pensions and AVCs" />
      <xs:enumeration value="Retail investments - Structured products" />
      <xs:enumeration value="Retail investments - DB pension transfers/safeguarded benefits" />
      <xs:enumeration value="Retail investments - NMPI/NRRS" />
      <xs:enumeration value="Retail investments - Other retail investment type" />
      <xs:enumeration value="Other FCA regulated business" />
      <xs:enumeration value="All other" />
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="PIIExclusionTimePeriodType">
    <xs:restriction base="xs:string">
      <xs:enumeration value="Past business" />
      <xs:enumeration value="Future business" />
      <xs:enumeration value="Past and future business" />
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="PIIExclusionCategoryType">
    <xs:restriction base="xs:string">
      <xs:enumeration value="All business" />
      <xs:enumeration value="Volume of business" />
      <xs:enumeration value="Type of consumer" />
      <xs:enumeration value="Type of business" />
      <xs:enumeration value="Sub-limit of cover" />
      <xs:enumeration value="Jurisdiction of insurers used" />
      <xs:enumeration value="Rating of insurer used" />
      <xs:enumeration value="Other" />
    </xs:restriction>
  </xs:simpleType>
   </xs:schema>
