    </xs:restriction>
  </xs:simpleType>
       
       

    
  
     <xs:complexType name="PIIPolicyExclusionStructure">
    <xs:sequence>
      <xs:element name="PolicyExclusion" type="PIIExclusionBusinessLineType" minOccurs="0" />
      <xs:element name="TimePeriod" type="PIIExclusionTimePeriodType" minOccurs="0" />
      <xs:element name="TypeOfExclusion" type="PIIExclusionCategoryType" minOccurs="0" />
    </xs:sequence>
  </xs:complexType>
  
       <xs:simpleType name="PIIExclusionBusinessLineType">
    <xs:restriction base="xs:string">
      <xs:enumeration value="No exclusions apply to this policy" />
      <xs:enumeration value="General insurance and pure protection - Standard/general" />
      <xs:enumeration value="General insurance and pure protection - Commercial" />
      <xs:enumeration value="General insurance and pure protection - Critical illness" />
      <xs:enumeration value="General insurance and pure protection - Income protection" />
      <xs:enumeration value="General insurance and pure protection - Delegated Authority Business" />
