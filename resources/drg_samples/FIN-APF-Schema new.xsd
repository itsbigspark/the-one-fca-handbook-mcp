                </xs:simpleType>
            </xs:element>
            <xs:element name="StartDate"         type="xs:date"                 minOccurs="0"/>
            <xs:element name="RenewalDate"       type="xs:date"                 minOccurs="0"/>       
            <xs:element name="RequiredIndemnityLimits" minOccurs="0">
